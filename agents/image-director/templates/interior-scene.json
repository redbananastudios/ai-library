{
  "name": "interior-scene",
  "description": "Room/interior — bathrooms, kitchens, showrooms",
  "version": "1.0.0",
  "category": "interior-scene",
  "base_model": "flux1-dev-fp8",
  "workflow": {
    "3": {
      "class_type": "KSampler",
      "inputs": {
        "seed": "{{seed}}",
        "steps": "{{steps}}",
        "cfg": "{{cfg_scale}}",
        "sampler_name": "{{sampler}}",
        "scheduler": "simple",
        "denoise": 1.0,
        "model": ["4", 0],
        "positive": ["6", 0],
        "negative": ["7", 0],
        "latent_image": ["5", 0]
      }
    },
    "4": {
      "class_type": "CheckpointLoaderSimple",
      "inputs": {
        "ckpt_name": "{{base_model}}.safetensors"
      }
    },
    "5": {
      "class_type": "EmptyLatentImage",
      "inputs": {
        "width": "{{width}}",
        "height": "{{height}}",
        "batch_size": "{{batch_size}}"
      }
    },
    "6": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "{{positive_prompt}}",
        "clip": ["4", 1]
      }
    },
    "7": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "{{negative_prompt}}",
        "clip": ["4", 1]
      }
    },
    "8": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["3", 0],
        "vae": ["4", 2]
      }
    },
    "9": {
      "class_type": "SaveImage",
      "inputs": {
        "filename_prefix": "interior",
        "images": ["8", 0]
      }
    }
  },
  "defaults": {
    "width": 1024,
    "height": 768,
    "steps": 20,
    "cfg_scale": 1,
    "sampler": "euler",
    "batch_size": 4,
    "negative_prompt": "blurry, low quality, distorted, deformed, watermark, cluttered, messy, unrealistic proportions, bad perspective, floating objects"
  },
  "prompt_template": "{subject}, interior design photography, natural window lighting, editorial style, clean composition, realistic materials and textures, architectural digest quality, high detail",
  "notes": "For Willow & Weir showroom/installation shots. Combines well with product and environment LoRAs. Updated for Flux 1 Dev FP8 (cfg=1, euler sampler, simple scheduler, 20 steps)."
}
