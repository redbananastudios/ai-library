# ─────────────────────────────────────────────────────────────────────
# Local environment template. Copy to .env.local and fill in.
# Vercel envs mirror this — set there for Production + Preview + Dev.
# ─────────────────────────────────────────────────────────────────────

# Sanity (project-specific)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_ADDRESS=quotes@send.example.com

# Google Places (form address autocomplete) — RESTRICT before launch:
#   - HTTP referrer: example.com/* + *.example.com/*
#   - API restriction: Maps JavaScript API + Places API only
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# Indexing gate. Set to 'true' ONLY in Vercel Production at cutover.
# Without this, the site stays noindex (canonical.ts checks both this
# AND VERCEL_ENV). Leaving unset prevents accidental indexing.
INDEXING_ENABLED=
